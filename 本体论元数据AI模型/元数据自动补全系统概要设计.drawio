        <mxCell id="lane_engine" value="元数据自动补全服务" style="swimlane;html=1;rounded=0;startSize=36;fillColor=#EEF7F1;strokeColor=#A9D1B5;fontColor=#27633A;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="510" y="130" width="620" height="770" as="geometry"/>
        </mxCell>
        <mxCell id="eng_context" value="1. 上下文采集与归一化&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;统一表字段、标准、血缘、模型、指标、报表、安全质量信息&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94C9A7;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_engine">
          <mxGeometry x="40" y="58" width="540" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="eng_evidence" value="2. 证据检索与候选召回&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;字段拆词、同名字段、相似资产、标准匹配、血缘上下游、历史确认样本&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94C9A7;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_engine">
          <mxGeometry x="40" y="154" width="540" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="eng_strategy" value="3. 组合生成策略&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;规则优先 + 标准映射 + 相似元数据 + 血缘语境 + 大模型生成&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94C9A7;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_engine">
          <mxGeometry x="40" y="256" width="540" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="eng_llm" value="4. 大模型补全编排&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Prompt 模板 / 上下文裁剪 / 敏感样例脱敏 / JSON 结构化输出&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDF5;strokeColor=#E4C66A;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_engine">
          <mxGeometry x="40" y="358" width="540" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="eng_score" value="5. 置信度与依据合成&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;高 / 中 / 低置信；记录命中标准、血缘证据、模型解释和风险提示&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94C9A7;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_engine">
          <mxGeometry x="40" y="460" width="540" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="eng_policy" value="6. 写入保护与任务候选区&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;不覆盖人工已确认内容；只写空值、待补全项和低质量备注候选&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94C9A7;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_engine">
          <mxGeometry x="40" y="562" width="540" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="eng_out" value="候选输出&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;表中文名 / 表备注 / 字段中文名 / 字段备注 / 业务含义 / 枚举说明 / 置信度 / 依据&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E9F7EF;strokeColor=#5AAF79;fontColor=#1F5134;fontSize=15;fontStyle=1;" vertex="1" parent="lane_engine">
          <mxGeometry x="40" y="664" width="540" height="76" as="geometry"/>
