        <mxCell id="proc_ui" value="处理确认页复用现有盘点弹窗&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;新增 AI 候选值、置信度、依据抽屉、只看待处理项、重试失败项&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E2AA61;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_process">
