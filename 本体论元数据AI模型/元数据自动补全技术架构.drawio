        <mxCell id="es" value="Elasticsearch&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;元数据检索、相似字段检索、历史确认样本检索、依据检索、语义资产搜索&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E6;strokeColor=#D97822;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_data">
          <mxGeometry x="1010" y="62" width="300" height="76" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="S3 对象存储&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;主要存放导入 Excel、导出 Excel、批量补全结果文件&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E6;strokeColor=#D97822;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_data">
