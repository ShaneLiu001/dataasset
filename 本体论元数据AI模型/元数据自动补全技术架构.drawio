        <mxCell id="ext_lineage" value="数据血缘接口&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;上下游、Join、任务链路、报表引用&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF7E8;strokeColor=#D28B22;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_external">
