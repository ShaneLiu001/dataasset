          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="feedback_flow" value="确认反馈复用逻辑：用户确认/修改/驳回候选值 -> 反馈服务记录 AI 候选值、人工最终值、差异、原因、上下文特征 -> GoldenDB 保存反馈样本 -> Kafka 发布样本索引事件 -> ES 建立相似样本索引 -> 下次补全时优先召回同系统、同主题域、同表名模式、同字段名/相似字段、同标准映射的历史确认样本。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F7FFF8;strokeColor=#9AD0A8;fontColor=#315D3F;fontSize=13;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="50" y="972" width="1820" height="46" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="设计原则：新增模块继续复用现有技术栈与部署体系；元数据补全服务优先服务现有资产盘点流程，轻量本体服务承接人工确认后的语义资产，确认反馈服务持续沉淀可复用样本，后续通过问数语义服务支撑报表平台 AI 问数。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D7DCE5;fontColor=#4B5563;fontSize=14;align=left;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="50" y="1026" width="1820" height="42" as="geometry"/>
        </mxCell>
