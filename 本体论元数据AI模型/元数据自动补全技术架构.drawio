        </mxCell>
        <mxCell id="ext_llm" value="大模型接口&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;中文名生成、备注生成、业务含义解释&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF7E8;strokeColor=#F2BD67;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_external">
          <mxGeometry x="625" y="58" width="270" height="66" as="geometry"/>
        </mxCell>
        <mxCell id="ext_metric" value="指标 / 建模平台接口&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;指标元数据、模型字段、主题域、分层&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF7E8;strokeColor=#D28B22;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_external">
