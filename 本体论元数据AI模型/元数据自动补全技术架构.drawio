        </mxCell>
        <mxCell id="ext_security" value="质量 / 安全 / 权限接口&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;质量规则、敏感扫描、安全等级、权限范围&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF7E8;strokeColor=#D28B22;fontColor=#263444;fontSize=15;" vertex="1" parent="lane_external">
          <mxGeometry x="1255" y="58" width="310" height="66" as="geometry"/>
        </mxCell>
        <mxCell id="ext_report" value="报表平台 / AI问数入口&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;二期消费轻量本体与问数语义服务&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F2ECFF;strokeColor=#7E65C7;fontColor=#533A9B;fontSize=15;" vertex="1" parent="lane_external">
